      "id": "arta-get-tx-001",
      "name": "Supabase: Get Transactions",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [880, 100],
      "alwaysOutputData": true,
      "credentials": { "supabaseApi": { "id": "xTHvppaIPCydn2CN", "name": "Supabase Account NARA" } }
