    {
      "parameters": {
        "jsCode": "const userId = $('Webhook').item.json.body.user_id;\nconst defaults = [\n  { name: 'Food & Drink', icon: '🍔', color: '#f59e0b', user_id: userId },\n  { name: 'Transport', icon: '🚗', color: '#3b82f6', user_id: userId },\n  { name: 'Shopping', icon: '🛍️', color: '#ec4899', user_id: userId },\n  { name: 'Entertainment', icon: '🎮', color: '#8b5cf6', user_id: userId },\n  { name: 'Health', icon: '💊', color: '#10b981', user_id: userId },\n  { name: 'Utilities', icon: '⚡', color: '#6b7280', user_id: userId }\n];\nreturn defaults.map(d => ({ json: d }));"
      },
